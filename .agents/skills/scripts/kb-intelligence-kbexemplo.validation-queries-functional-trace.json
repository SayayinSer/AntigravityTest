        "workwith_transaction_binding",
        "workwith_condition_procedure"
      ],
      "expected_reading_plan_files": [
        "WorkWithForWeb/WorkWithWebOrdemDeProducao.xml"
      ]
    },
    {
      "id": "phase6-case-2-procedure-bc-functional-trace",
