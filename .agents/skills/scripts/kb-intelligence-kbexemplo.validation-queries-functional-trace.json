      "expected_trace_sources": [
        "WorkWithForWeb:WorkWithWebOrdemDeProducao"
      ],
      "expected_trace_targets": [
        "Transaction:ItemDeEstoque"
      ],
      "expected_rules": [
        "source_bc_load_transaction",
        "source_bc_save_transaction"
      ],
      "expected_reading_plan_files": [
