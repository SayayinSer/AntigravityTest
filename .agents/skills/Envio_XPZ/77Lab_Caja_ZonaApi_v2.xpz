<Object parentGuid="afa47377-41d5-4ae8-9755-6f53150aa361" user="FACTORIAGX\Sergio" versionDate="0001-01-01T00:00:00.0000000" lastUpdate="2026-05-05T19:40:00.0000000Z" checksum="" fullyQualifiedName="Caja" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="5563a999-f468-42f9-b294-422c0ff06a8f" name="Caja" type="1db606f2-af09-4cf9-a3b5-b481519d28f6" description="Caja">
  <Part type="264be5fb-1b28-4b25-a598-6ca900dd059f">
    <Level Name="Caja" Type="Caja" Description="Caja" Guid="5563a999-f468-42f9-b294-422c0ff06a8f">
      <Properties />
      <Attribute key="True" guid="d8747a67-d8b0-4d3e-8e39-c4d8808facd7">CajaId</Attribute>
      <Attribute key="False" guid="dca098b4-00e2-4c1d-a26f-b2a670dbb073">CajaDescripcion</Attribute>
      <Attribute key="False" guid="00393a75-9355-41f8-9e1b-71b2f932cac3">CajaEstado</Attribute>
      <Attribute key="False" guid="a064627a-778f-44c9-8762-05a40bc55c12">CajaSaldoInicial</Attribute>
      <Attribute key="False" guid="80f556ae-38aa-4541-885a-d76bc303e360">
        <Name>CajaTotalIngresos</Name>
        <Properties>
          <Property><Name>Formula</Name><Value>sum(MovimientoCajaImporte) where MovimientoCajaTipo = "I"</Value></Property>
        </Properties>
      </Attribute>
      <Attribute key="False" guid="891a7d85-c6c1-4724-9315-f02287690ce8">
        <Name>CajaTotalEgresos</Name>
        <Properties>
          <Property><Name>Formula</Name><Value>sum(MovimientoCajaImporte) where MovimientoCajaTipo = "E"</Value></Property>
        </Properties>
      </Attribute>
      <Attribute key="False" guid="5faf2f35-4e8f-4f0c-a634-0b1f1334305d">CajaSaldoActual</Attribute>
    </Level>
    <Properties />
  </Part>
  <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
    <Source><![CDATA[default(CajaEstado, "A");
CajaSaldoActual = CajaSaldoInicial + CajaTotalIngresos - CajaTotalEgresos;]]></Source>
    <Properties />
  </Part>
  <Properties>
    <Property><Name>Name</Name><Value>Caja</Value></Property>
    <Property><Name>idISBUSINESSCOMPONENT</Name><Value>True</Value></Property>
  </Properties>
</Object>
