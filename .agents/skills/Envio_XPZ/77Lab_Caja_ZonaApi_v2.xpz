<Object parentGuid="afa47377-41d5-4ae8-9755-6f53150aa361" user="FACTORIAGX\Sergio" versionDate="0001-01-01T00:00:00.0000000" lastUpdate="2026-05-05T19:40:00.0000000Z" checksum="" fullyQualifiedName="InitConceptosCaja" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="c0b9a42a-2570-429b-80c4-ad52be36f77d" name="InitConceptosCaja" type="84a12143-3242-4a54-939e-64d054572011" description="Init Conceptos de Caja">
  <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
    <Source><![CDATA[new
    ConceptoCajaNombre = "Gasto de Movilidad"
endnew
new
    ConceptoCajaNombre = "Pago de servicios"
endnew
new
    ConceptoCajaNombre = "Cobro de Deuda"
endnew
commit]]></Source>
