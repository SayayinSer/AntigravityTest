<Object parentGuid="afa47377-41d5-4ae8-9755-6f53150aa361" user="FACTORIAGX\Sergio" versionDate="0001-01-01T00:00:00.0000000" lastUpdate="2026-05-05T20:00:00.0000000Z" checksum="" fullyQualifiedName="ZonaApi" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="568a7b32-3d28-4fca-89f8-d24c82eb8d7b" name="ZonaApi" type="dcd3395a-7fcd-400a-867f-94a50d242555" description="Zona API CRUD">
  <Part type="d24a58ad-57ba-41b7-9e6e-eaca3543c778">
    <Source><![CDATA[Service Zonas
{
    [RestMethod: POST]
    [Path: "/"]
    Insert(in:&Zona, out:&Messages) => ZonaInsert(&Zona, &Messages);

    [RestMethod: PUT]
    [Path: "/{ZonaCodigo}"]
    Update(in:&Zona, out:&Messages) => ZonaUpdate(&Zona, &Messages);

    [RestMethod: DELETE]
    [Path: "/{ZonaCodigo}"]
    Delete(in:&ZonaCodigo, out:&Messages) => ZonaDelete(&ZonaCodigo, &Messages);

    [RestMethod: GET]
    [Path: "/{ZonaCodigo}"]
    GetByKey(in:&ZonaCodigo, out:&Zona, out:&Messages) => ZonaGetByKey(&ZonaCodigo, &Zona, &Messages);

    [RestMethod: GET]
    [Path: "/"]
    GetAll(out:&Zonas) => ZonaGetAll(&Zonas);
}]]></Source>
  </Part>
  <Part type="e4c4ade7-53f0-4a56-bdfd-843735b66f47">
