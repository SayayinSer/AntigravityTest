<Object parentGuid="afa47377-41d5-4ae8-9755-6f53150aa361" user="FACTORIAGX\Sergio" versionDate="0001-01-01T00:00:00.0000000" lastUpdate="2026-05-05T20:00:00.0000000Z" checksum="" fullyQualifiedName="ZonaGetAll" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="5f281e07-104d-4a6e-b971-a03cd43cf66e" name="ZonaGetAll" type="84a12143-3242-4a54-939e-64d054572011" description="ZonaGetAll">
  <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
    <Source><![CDATA[for each order ZonaNombre
  &Zona = new()
  &Zona.ZonaCodigo = ZonaCodigo
  &Zona.ZonaNombre = ZonaNombre
  &Zonas.Add(&Zona)
endfor]]></Source>
  </Part>
  <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
    <Source><![CDATA[parm(out:&Zonas);]]></Source>
  </Part>
