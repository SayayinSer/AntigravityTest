    </Object>

    <!-- apiWorkOrder -->
    <Object type="de43003a-c0e7-4de0-9112-921d7bba4e24" guid="2b3c4d5e-6f7a-8b9c-0d1e-2f3a4b5c6d7e" name="apiWorkOrder">
      <Part type="c414d7a4-e9cb-4ba3-bfaf-f2fb50b55615">
        <Source><![CDATA[Service WorkOrder
{
    [RestMethod: GET]
    [Path: "/workorder"]
    => GetWorkOrders(out:&SDTWorkOrders);

    [RestMethod: GET]
    [Path: "/workorder/{id}"]
    => GetWorkOrderById(in:&id, out:&SDTWorkOrder);

    [RestMethod: POST]
    [Path: "/workorder"]
    => InsertWorkOrder(in:&SDTWorkOrder, out:&Messages);

    [RestMethod: PUT]
    [Path: "/workorder/{id}"]
    => UpdateWorkOrder(in:&id, in:&SDTWorkOrder, out:&Messages);

