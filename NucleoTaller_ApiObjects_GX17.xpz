    => GetAppointments(out:&SDTAppointments);

    [RestMethod: GET]
    [Path: "/appointment/{id}"]
    => GetAppointmentById(in:&id, out:&SDTAppointment);

    [RestMethod: POST]
    [Path: "/appointment"]
    => InsertAppointment(in:&SDTAppointment, out:&Messages);

    [RestMethod: PUT]
    [Path: "/appointment/{id}"]
    => UpdateAppointment(in:&id, in:&SDTAppointment, out:&Messages);

    [RestMethod: DELETE]
    [Path: "/appointment/{id}"]
    => DeleteAppointment(in:&id, out:&Messages);
}]]></Source>
