  <Objects>
    <!-- apiOwner -->
    <Object type="de43003a-c0e7-4de0-9112-921d7bba4e24" guid="9b29dbcd-2245-4277-bc65-037fcdbbbb11" name="apiOwner">
      <Part type="c414d7a4-e9cb-4ba3-bfaf-f2fb50b55615">
        <Source><![CDATA[Service Owner
{
    [RestMethod: GET]
    [Path: "/owner"]
    => GetOwners(out:&SDTOwners);

    [RestMethod: GET]
    [Path: "/owner/{id}"]
    => GetOwnerById(in:&id, out:&SDTOwner);

    [RestMethod: POST]
    [Path: "/owner"]
    => InsertOwner(in:&SDTOwner, out:&Messages);

    [RestMethod: PUT]
    [Path: "/owner/{id}"]
    => UpdateOwner(in:&id, in:&SDTOwner, out:&Messages);

    [RestMethod: DELETE]
    [Path: "/owner/{id}"]
    => DeleteOwner(in:&id, out:&Messages);
}]]></Source>
      </Part>
    </Object>

    <!-- apiVehicle -->
    <Object type="de43003a-c0e7-4de0-9112-921d7bba4e24" guid="a1b2c3d4-e5f6-4788-b9a0-c1d2e3f4a5b6" name="apiVehicle">
      <Part type="c414d7a4-e9cb-4ba3-bfaf-f2fb50b55615">
        <Source><![CDATA[Service Vehicle
{
    [RestMethod: GET]
    [Path: "/vehicle"]
    => GetVehicles(out:&SDTVehicles);

    [RestMethod: GET]
    [Path: "/vehicle/{id}"]
    => GetVehicleById(in:&id, out:&SDTVehicle);

    [RestMethod: POST]
    [Path: "/vehicle"]
    => InsertVehicle(in:&SDTVehicle, out:&Messages);

    [RestMethod: PUT]
    [Path: "/vehicle/{id}"]
    => UpdateVehicle(in:&id, in:&SDTVehicle, out:&Messages);

    [RestMethod: DELETE]
    [Path: "/vehicle/{id}"]
    => DeleteVehicle(in:&id, out:&Messages);
}]]></Source>
      </Part>
    </Object>

